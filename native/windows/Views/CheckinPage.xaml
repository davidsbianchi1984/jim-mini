<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JimGuardian.Views.CheckinPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource JimScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="16" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Check-in" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource JimTxtBrush}" />
            <TextBlock Text="A quick pulse on how you're doing."
                       Foreground="{StaticResource JimT2Brush}" FontSize="13" />

            <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="12">
                    <Slider x:Name="Mood" Header="Mood" Minimum="1" Maximum="5" Value="3"
                            StepFrequency="1" TickFrequency="1" TickPlacement="Outside" />
                    <Slider x:Name="Energy" Header="Energy" Minimum="1" Maximum="5" Value="3"
                            StepFrequency="1" TickFrequency="1" TickPlacement="Outside" />
                    <TextBox x:Name="NoteBox" Header="Note" PlaceholderText="Anything on your mind?"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="72" />
                </StackPanel>
            </Border>

            <Button x:Name="LogButton" Content="Log check-in" Height="46" HorizontalAlignment="Stretch"
                    Foreground="White" Click="OnLog">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{StaticResource JimBrandA}" Offset="0" />
                        <GradientStop Color="#FF3AA0FF" Offset="1" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <Border x:Name="GuidanceCard" Background="{StaticResource JimCardBrush}"
                    BorderBrush="{StaticResource JimLineBrush}" BorderThickness="1" CornerRadius="16"
                    Padding="16" Visibility="Collapsed">
                <StackPanel Spacing="6">
                    <TextBlock Text="Guidance" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource JimTxtBrush}" />
                    <TextBlock x:Name="GuidanceText" Foreground="{StaticResource JimTxtBrush}"
                               FontSize="14" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
