<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JimGuardian.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource JimScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="9" Height="9" Fill="{StaticResource JimGreenBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Guardian on · watching" Foreground="{StaticResource JimGreenBrush}"
                           FontWeight="Bold" FontSize="12" />
            </StackPanel>
            <TextBlock x:Name="Greeting" FontSize="28" FontWeight="Bold" Foreground="{StaticResource JimTxtBrush}" />
            <TextBlock Text="Your Guardian is watching — the rules are transparent."
                       Foreground="{StaticResource JimT2Brush}" FontSize="14" TextWrapping="Wrap" />
            <Button x:Name="RefreshButton" Content="Refresh" Click="OnRefresh"
                    Background="Transparent" FontSize="12"
                    Foreground="{StaticResource JimBrandABrush}" />

            <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Learned baseline" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource JimTxtBrush}" />
                    <ProgressRing x:Name="Loading" IsActive="True" Foreground="{StaticResource JimBrandABrush}"
                                  Width="24" Height="24" HorizontalAlignment="Left" />
                    <TextBlock x:Name="Empty" Text="No baseline yet — it builds from calm samples in Live Monitoring."
                               Foreground="{StaticResource JimT2Brush}" FontSize="13" Visibility="Collapsed"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="MetricsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4">
                                    <TextBlock Text="{Binding Metric}" Foreground="{StaticResource JimTxtBrush}"
                                               HorizontalAlignment="Left" />
                                    <TextBlock Text="{Binding Display}" Foreground="{StaticResource JimT2Brush}"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Model" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource JimTxtBrush}" />
                    <TextBlock Text="Which LLM powers your coaching and guidance."
                               Foreground="{StaticResource JimT2Brush}" FontSize="12" TextWrapping="Wrap" />
                    <ComboBox x:Name="ProviderBox" HorizontalAlignment="Stretch"
                              SelectionChanged="OnProviderPicked" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Language" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource JimTxtBrush}" />
                    <TextBlock Text="Everything drafted for you — guidance, coaching, first-aid steps, waiver terms — is delivered in this language."
                               Foreground="{StaticResource JimT2Brush}" FontSize="12" TextWrapping="Wrap" />
                    <ComboBox x:Name="LanguageBox" HorizontalAlignment="Stretch"
                              SelectionChanged="OnLanguagePicked" />
                    <ToggleSwitch x:Name="PreTranslateToggle" Header="Pre-translate everything"
                                  OnContent="Everything arrives translated"
                                  OffContent="Originals kept — translate below"
                                  IsOn="True" Toggled="OnModeToggled" />
                    <TextBox x:Name="TranslateBox" Header="Translate anything"
                             PlaceholderText="Paste or type text…" />
                    <Button Content="Translate" Click="OnTranslate"
                            Background="{StaticResource JimBrandABrush}" Foreground="White" FontSize="12" />
                    <TextBlock x:Name="TranslateOut" FontSize="13" TextWrapping="Wrap"
                               Foreground="{StaticResource JimTxtBrush}" Visibility="Collapsed" />
                    <TextBlock x:Name="TranslateEngine" FontSize="10" TextWrapping="Wrap"
                               Foreground="{StaticResource JimT2Brush}" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Help us improve" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource JimTxtBrush}" />
                    <TextBlock Text="Tell us how to make the app better — an idea, a rough edge, a bug, or what you love. It goes straight to the team."
                               Foreground="{StaticResource JimT2Brush}" FontSize="12" TextWrapping="Wrap" />
                    <ComboBox x:Name="ImproveCategory" Header="Category" HorizontalAlignment="Stretch" />
                    <TextBox x:Name="ImproveMessage" PlaceholderText="What's on your mind?"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="80" />
                    <ComboBox x:Name="ImproveRating" Header="Rating (optional)" HorizontalAlignment="Stretch" />
                    <Button Content="Send feedback" Click="OnSendImprovement"
                            Background="{StaticResource JimBrandABrush}" Foreground="White" FontSize="12" />
                    <TextBlock x:Name="ImproveThanks" Foreground="{StaticResource JimGreenBrush}" FontSize="12"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                    <TextBlock x:Name="ImproveTally" Foreground="{StaticResource JimT2Brush}" FontSize="11"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                    <TextBlock x:Name="ImproveMineHeader" Text="Yours" FontWeight="Bold" FontSize="12"
                               Foreground="{StaticResource JimTxtBrush}" Visibility="Collapsed" />
                    <ItemsControl x:Name="ImproveMine">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Line}" Foreground="{StaticResource JimT2Brush}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
