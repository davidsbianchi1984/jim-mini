<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JimGuardian.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource JimScrBotBrush}">

    <NavigationView x:Name="Nav" IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                    PaneDisplayMode="Left" SelectionChanged="OnSelectionChanged"
                    Background="{StaticResource JimScrBotBrush}">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Overview" Tag="overview" IsSelected="True">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Home" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Live Monitoring" Tag="monitor">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Important" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Check-in" Tag="checkin">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Emoji2" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Coach" Tag="coach">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Message" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Life" Tag="life">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Flag" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Safety" Tag="safety">
                <NavigationViewItem.Icon><SymbolIcon Symbol="ReportHacked" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Connect" Tag="connect">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Link" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Vault Custody" Tag="custody">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Permissions" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.PaneFooter>
            <Button Content="Sign out" Margin="12" Click="OnSignOut"
                    Foreground="{StaticResource JimT2Brush}" Background="Transparent" />
        </NavigationView.PaneFooter>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
