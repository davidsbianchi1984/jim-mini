<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JimGuardian.Views.LifePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource JimScrBotBrush}">

    <Pivot MaxWidth="680" Margin="20,12" Foreground="{StaticResource JimTxtBrush}">

        <!-- Goals -->
        <PivotItem Header="Goals">
            <ScrollViewer>
                <StackPanel Spacing="12" Padding="4">
                    <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                            BorderThickness="1" CornerRadius="16" Padding="16">
                        <StackPanel Spacing="10">
                            <ComboBox x:Name="GoalArea" Header="Area" SelectedIndex="5" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="mental_health" />
                                <ComboBoxItem Content="health_fitness" />
                                <ComboBoxItem Content="career" />
                                <ComboBoxItem Content="finance" />
                                <ComboBoxItem Content="relationships" />
                                <ComboBoxItem Content="personal_growth" />
                            </ComboBox>
                            <TextBox x:Name="GoalTitle" Header="Title" PlaceholderText="What do you want to achieve?" />
                            <Button Content="Add goal" HorizontalAlignment="Stretch" Height="42"
                                    Foreground="White" Click="OnAddGoal">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{StaticResource JimBrandA}" Offset="0" />
                                        <GradientStop Color="#FF3AA0FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </Border>
                    <ItemsControl x:Name="GoalsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                                        BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                   Foreground="{StaticResource JimTxtBrush}" />
                                        <TextBlock Text="{Binding Meta}" Foreground="{StaticResource JimT2Brush}" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <!-- Habits -->
        <PivotItem Header="Habits">
            <ScrollViewer>
                <StackPanel Spacing="12" Padding="4">
                    <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                            BorderThickness="1" CornerRadius="16" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBox x:Name="HabitName" Header="Name" PlaceholderText="e.g. Walk 20 minutes" />
                            <Button Content="Add habit" HorizontalAlignment="Stretch" Height="42"
                                    Foreground="White" Click="OnAddHabit">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{StaticResource JimBrandA}" Offset="0" />
                                        <GradientStop Color="#FF3AA0FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </Border>
                    <ItemsControl x:Name="HabitsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                                        BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                       Foreground="{StaticResource JimTxtBrush}" />
                                            <TextBlock Text="{Binding Streak}" Foreground="{StaticResource JimT2Brush}" FontSize="12" />
                                        </StackPanel>
                                        <Button Content="Log" Tag="{Binding Id}" Click="OnLogHabit"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Background="Transparent" Foreground="{StaticResource JimBrandABrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <!-- Journal -->
        <PivotItem Header="Journal">
            <ScrollViewer>
                <StackPanel Spacing="12" Padding="4">
                    <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                            BorderThickness="1" CornerRadius="16" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBox x:Name="JournalText" Header="Entry" PlaceholderText="How was today?"
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="90" />
                            <Button Content="Save entry" HorizontalAlignment="Stretch" Height="42"
                                    Foreground="White" Click="OnAddJournal">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{StaticResource JimBrandA}" Offset="0" />
                                        <GradientStop Color="#FF3AA0FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </Border>
                    <ItemsControl x:Name="JournalList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource JimCardBrush}" BorderBrush="{StaticResource JimLineBrush}"
                                        BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource JimTxtBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Date}" Foreground="{StaticResource JimT2Brush}" FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>
    </Pivot>
</Page>
