<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="JimGuardian.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- JIM-mini / Guardian dark-OLED palette -->
            <Color x:Key="JimScrBot">#FF0A0F1C</Color>
            <Color x:Key="JimCard">#FF182238</Color>
            <Color x:Key="JimLine">#FF26314E</Color>
            <Color x:Key="JimTxt">#FFEEF1F7</Color>
            <Color x:Key="JimT2">#FF8A94AD</Color>
            <Color x:Key="JimBrandA">#FF7C5CFF</Color>
            <Color x:Key="JimGreen">#FF43E08A</Color>
            <Color x:Key="JimRed">#FFFF3B30</Color>
            <SolidColorBrush x:Key="JimScrBotBrush" Color="{StaticResource JimScrBot}" />
            <SolidColorBrush x:Key="JimCardBrush" Color="{StaticResource JimCard}" />
            <SolidColorBrush x:Key="JimLineBrush" Color="{StaticResource JimLine}" />
            <SolidColorBrush x:Key="JimTxtBrush" Color="{StaticResource JimTxt}" />
            <SolidColorBrush x:Key="JimT2Brush" Color="{StaticResource JimT2}" />
            <SolidColorBrush x:Key="JimBrandABrush" Color="{StaticResource JimBrandA}" />
            <SolidColorBrush x:Key="JimGreenBrush" Color="{StaticResource JimGreen}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
